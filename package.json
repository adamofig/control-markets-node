{
  "name": "scaffolddataclouder-node",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "publish:notion": "cd libs/notion && npm run publish:npm && cd ../../",
    "update:dc": "pnpm install @dataclouder/nest-core@latest @dataclouder/nest-storage@latest @dataclouder/nest-agent-cards@latest @dataclouder/nest-mongo@latest @dataclouder/nest-google-cloud@latest  @dataclouder/nest-users@latest @dataclouder/nest-auth@latest @dataclouder/nest-ai-services-sdk@latest @dataclouder/nest-ai-services-mongodb@latest --force",
    "remove:mongo": "rm -rf dist/libs/nest-mongo && echo 'removed dist/libs/nest-mongo'",
    "patch:mongo": "cd libs/nest-mongo && npm version patch && echo 'patched nest-mongo'",
    "build:mongo": "cd libs/nest-mongo && npm run build && npm version patch && cp package.json ../../dist/libs/nest-mongo/ && echo 'built nest-mongo'",
    "publish:mongo": "npm run build:mongo && cd ./dist/libs/nest-mongo && npm publish && echo 'published nest-mongo'",
    "build-publish:mongo": "npm run remove:mongo && npm run patch:mongo && npm run build:mongo && npm publish:mongo",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.25.1",
    "@ai-sdk/google": "^3.0.88",
    "@dataclouder/nest-agent-cards": "^0.1.53",
    "@dataclouder/nest-ai-services-mongodb": "^0.0.9",
    "@dataclouder/nest-ai-services-sdk": "^0.0.7",
    "@dataclouder/nest-auth": "^1.0.0",
    "@dataclouder/nest-core": "^1.0.0",
    "@dataclouder/nest-google-cloud": "^0.1.15",
    "@dataclouder/nest-knowledge": "^0.0.1",
    "@dataclouder/nest-mongo": "^1.1.2",
    "@dataclouder/nest-storage": "^1.0.4",
    "@dataclouder/nest-users": "^0.0.10",
    "@dataclouder/notion": "^0.0.4",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^8.3.0",
    "@google-cloud/text-to-speech": "^5.8.1",
    "@google/genai": "^1.52.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.5",
    "@notionhq/client": "^5.22.0",
    "@rekog/mcp-nest": "^1.9.10",
    "@saintno/comfyui-sdk": "^0.3.1",
    "@stable-canvas/comfyui-client": "^1.5.9",
    "@types/node-notifier": "^8.0.5",
    "@webundsoehne/nest-fastify-file-upload": "^2.3.1",
    "ai": "^6.0.219",
    "axios": "^1.18.1",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cron": "^4.4.0",
    "date-fns": "^4.4.0",
    "discord.js": "^14.26.4",
    "dotenv": "^16.6.1",
    "es-toolkit": "^1.49.0",
    "fast-glob": "^3.3.3",
    "fastify": "^5.10.0",
    "firebase-admin": "^13.10.0",
    "fluent-ffmpeg": "^2.1.3",
    "google-auth-library": "^9.15.1",
    "groq-sdk": "^0.15.0",
    "mongodb": "^6.21.0",
    "mongoose": "^8.24.1",
    "node-notifier": "^10.0.1",
    "ollama-ai-provider": "^1.2.0",
    "passport": "^0.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.35.3",
    "youtube-transcript": "^1.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.13.2",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^29.7.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@dataclouder/nest-mongo(|/.*)$": "<rootDir>/libs/nest-mongo/src/$1"
    }
  },
  "pnpm": {
    "allowBuilds": {
      "@firebase/util": true,
      "@nestjs/core": true,
      "@scarf/scarf": true,
      "@swc/core": true,
      "protobufjs": true,
      "sharp": true
    }
  }
}
